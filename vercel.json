{
  "rewrites": [
    { "source": "/", "destination": "/Frontendindex.html" },
    { "source": "/html/:path*", "destination": "/Frontend/html/:path*" },
    { "source": "/css/:path*", "destination": "/Frontend/css/:path*" },
    { "source": "/CSS/:path*", "destination": "/Frontend/css/:path*" },
    { "source": "/Javascript/:path*", "destination": "/Frontend/Javascript/:path*" },
    { "source": "/:path*", "destination": "/Frontend/:path*" }
  ]
}